# User config and runtime data
config.yaml
registry.db

# KB data (databases, exports, per-KB configs)
knowledge-bases/

# Python
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/

# Pytest / coverage
.pytest_cache/
.coverage
htmlcov/

# Bundled tools — user-provided binaries, not tracked in source control
